# === SINDYCONDO - Ambiente TU (Teste de Usuário) ===
# Copie para .env e preencha com os valores reais

DEBUG=False
SECRET_KEY=gere-uma-chave-segura-com-python-secrets

# Imagem Docker
GITHUB_IMAGE=ciceroregis/sindycondo-backend

# === DATABASE ===
POSTGRES_DB=sindycondo_tu
POSTGRES_USER=sindycondo_tu_user
POSTGRES_PASSWORD=senha-segura-tu
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === CORS ===
CORS_ALLOWED_ORIGINS=https://tu.sindycondo.com.br

# === HOSTS ===
ALLOWED_HOSTS=tu.api.sindycondo.com.br

# === ADMIN ===
ADMIN_URL_PATH=admin/

# === PGADMIN ===
PGADMIN_EMAIL=admin@sindycondo.com.br
PGADMIN_PASSWORD=senha-segura-pgadmin-tu

# === TWILIO (WhatsApp) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# === FIREBASE (Push) ===
FCM_SERVER_KEY=

# === AMBIENTE ===
ENVIRONMENT=tu
