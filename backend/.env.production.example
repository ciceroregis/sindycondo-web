# === SINDYCONDO - Produção ===
# Copie para .env e preencha com os valores reais

DEBUG=False
SECRET_KEY=gere-uma-chave-segura-com-python-secrets

# Imagens Docker (preencher com: seu-usuario/seu-repo)
GITHUB_IMAGE=ciceroregis/sindycondo-backend
GITHUB_FRONTEND_IMAGE=ciceroregis/sindycondo-frontend

# === DATABASE ===
POSTGRES_DB=sindycondo
POSTGRES_USER=sindycondo_user
POSTGRES_PASSWORD=senha-segura-aqui
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === CORS ===
CORS_ALLOWED_ORIGINS=https://sindycondo.com.br,https://www.sindycondo.com.br

# === HOSTS ===
ALLOWED_HOSTS=api.sindycondo.com.br

# === ADMIN ===
ADMIN_URL_PATH=mude-este-caminho-secreto/

# === TRAEFIK DASHBOARD ===
# Gerar com: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
# Ou via Docker: docker run --rm httpd:alpine htpasswd -nB admin
TRAEFIK_AUTH=admin:$$2y$$05$$troque-este-hash-aqui

# === PGADMIN ===
PGADMIN_EMAIL=admin@sindycondo.com.br
PGADMIN_PASSWORD=senha-segura-pgadmin

# === TWILIO (WhatsApp) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# === FIREBASE (Push) ===
FCM_SERVER_KEY=

# === AMBIENTE ===
ENVIRONMENT=production
